# Copy this file to ".env" and fill in real values.
# ".env" itself is in .gitignore and will never be committed.

# Get a fresh key from https://aistudio.google.com/apikey
# (the previous key was leaked via being hardcoded in config.py and committed
# to this public repo — Google auto-revoked it. Never hardcode a real key again.)
GEMINI_API_KEY=your-new-gemini-api-key-here

# Optional — override the model used for all AI calls (default: gemini-3.5-flash)
# GEMINI_MODEL=gemini-3.5-flash

# Optional — Flask session signing key. If omitted, a random one is generated
# each time the app starts (fine for local dev; sessions just won't survive a restart).
# SECRET_KEY=some-random-string

# Optional — only needed if using Postgres instead of the default local SQLite file
# DATABASE_URL=postgresql://user:password@host:5432/dbname
